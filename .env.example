# Copy to .env and fill in the keys for the providers you want to use.
# The gateway only needs keys for providers your routing.yaml actually targets.
# .env is gitignored — never commit real keys.

# --- Provider API keys -------------------------------------------------------
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
GEMINI_API_KEY=...            # API key from https://aistudio.google.com/apikey (NOT a Vertex SA)
DEEPSEEK_API_KEY=sk-...

# --- Optional base-URL overrides (proxies / compatible gateways) -------------
# OPENAI_BASE_URL=https://api.openai.com/v1
# DEEPSEEK_BASE_URL=https://api.deepseek.com/v1

# --- Optional spend ledger + caps (disabled by default) ----------------------
# LLM_GATEWAY_LEDGER=1
# LLM_GATEWAY_LEDGER_PATH=./.llm_gateway/ledger.db
# LLM_GATEWAY_CAP_TOTAL_MONTHLY=500
# LLM_GATEWAY_CAP_OPENAI_MONTHLY=200

# --- Optional kill switches (work without the ledger) ------------------------
# LLM_GATEWAY_DISABLED=1            # block all calls
# LLM_GATEWAY_EXPENSIVE_DISABLED=1  # block any projected call > $1
